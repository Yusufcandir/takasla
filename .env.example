# === API Gateway ===
API_GATEWAY_PORT=3000

# === Auth Service ===
AUTH_SERVICE_PORT=3001
AUTH_DB_HOST=postgres-auth
AUTH_DB_PORT=5432
AUTH_DB_NAME=auth_db
AUTH_DB_USER=exchange
AUTH_DB_PASSWORD=exchange_dev_password
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# === User Service ===
USER_SERVICE_PORT=3002
USER_DB_HOST=postgres-user
USER_DB_PORT=5432
USER_DB_NAME=user_db
USER_DB_USER=exchange
USER_DB_PASSWORD=exchange_dev_password

# === Listing Service ===
LISTING_SERVICE_PORT=3003
LISTING_DB_HOST=postgres-listing
LISTING_DB_PORT=5432
LISTING_DB_NAME=listing_db
LISTING_DB_USER=exchange
LISTING_DB_PASSWORD=exchange_dev_password

# === Offer Service ===
OFFER_SERVICE_PORT=3004
OFFER_DB_HOST=postgres-offer
OFFER_DB_PORT=5432
OFFER_DB_NAME=offer_db
OFFER_DB_USER=exchange
OFFER_DB_PASSWORD=exchange_dev_password

# === Trade Service ===
TRADE_SERVICE_PORT=3005
TRADE_DB_HOST=postgres-trade
TRADE_DB_PORT=5432
TRADE_DB_NAME=trade_db
TRADE_DB_USER=exchange
TRADE_DB_PASSWORD=exchange_dev_password

# === Reputation Service ===
REPUTATION_SERVICE_PORT=3006
REPUTATION_DB_HOST=postgres-reputation
REPUTATION_DB_PORT=5432
REPUTATION_DB_NAME=reputation_db
REPUTATION_DB_USER=exchange
REPUTATION_DB_PASSWORD=exchange_dev_password

# === Dispute Service ===
DISPUTE_SERVICE_PORT=3007
DISPUTE_DB_HOST=postgres-dispute
DISPUTE_DB_PORT=5432
DISPUTE_DB_NAME=dispute_db
DISPUTE_DB_USER=exchange
DISPUTE_DB_PASSWORD=exchange_dev_password

# === Certificate Service ===
CERTIFICATE_SERVICE_PORT=3008
CERTIFICATE_DB_HOST=postgres-certificate
CERTIFICATE_DB_PORT=5432
CERTIFICATE_DB_NAME=certificate_db
CERTIFICATE_DB_USER=exchange
CERTIFICATE_DB_PASSWORD=exchange_dev_password

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379

# === RabbitMQ ===
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=exchange
RABBITMQ_PASSWORD=exchange_dev_password
RABBITMQ_MANAGEMENT_PORT=15672

# === Blockchain (Sepolia) ===
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
SEPOLIA_PRIVATE_KEY=your-deployer-private-key
MERKLE_ANCHOR_CONTRACT_ADDRESS=
