{
  "name": "@exchange/payment-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "db:migrate": "typeorm migration:run -d dist/data-source.js",
    "db:migrate:generate": "typeorm migration:generate -d dist/data-source.js",
    "db:migrate:revert": "typeorm migration:revert -d dist/data-source.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@exchange/shared-types": "workspace:*",
    "@exchange/common": "workspace:*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/typeorm": "^10.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "iyzipay": "^1.0.68",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@types/jest": "^29.5.11",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.4.0"
  }
}
