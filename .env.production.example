# =============================================================================
# Exchange Platform — Production Environment
# =============================================================================
# Copy this to .env and fill in all values before deploying.
# NEVER commit .env to git (it's in .gitignore).
# =============================================================================

# === Domain & URLs ===
# Replace YOURNAME with your DuckDNS subdomain
NEXT_PUBLIC_API_URL=https://YOURNAME.duckdns.org/api
FRONTEND_URL=https://YOURNAME.duckdns.org

# === JWT (CRITICAL — generate unique secrets) ===
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=GENERATE_A_STRONG_SECRET_HERE
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# === API Gateway ===
API_GATEWAY_PORT=3000

# === Email Verification (Gmail SMTP) ===
# Create App Password: Google Account > Security > 2-Step Verification > App Passwords
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# === Database Passwords ===
# Generate each one separately with: openssl rand -base64 24
AUTH_DB_PASSWORD=GENERATE_UNIQUE_PASSWORD
USER_DB_PASSWORD=GENERATE_UNIQUE_PASSWORD
LISTING_DB_PASSWORD=GENERATE_UNIQUE_PASSWORD
OFFER_DB_PASSWORD=GENERATE_UNIQUE_PASSWORD
TRADE_DB_PASSWORD=GENERATE_UNIQUE_PASSWORD
REPUTATION_DB_PASSWORD=GENERATE_UNIQUE_PASSWORD
DISPUTE_DB_PASSWORD=GENERATE_UNIQUE_PASSWORD
CERTIFICATE_DB_PASSWORD=GENERATE_UNIQUE_PASSWORD
SHIPPING_DB_PASSWORD=GENERATE_UNIQUE_PASSWORD
PAYMENT_DB_PASSWORD=GENERATE_UNIQUE_PASSWORD

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379

# === RabbitMQ ===
# Generate with: openssl rand -base64 24
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=exchange
RABBITMQ_PASSWORD=GENERATE_UNIQUE_PASSWORD

# === Shipping (Geliver — Turkish carrier aggregator) ===
# Get token from geliver.com dashboard
GELIVER_TOKEN=
GELIVER_TEST_MODE=false
EASYPOST_API_KEY=

# === Blockchain (Sepolia) — leave blank for simulation mode ===
SEPOLIA_RPC_URL=
SEPOLIA_PRIVATE_KEY=
MERKLE_ANCHOR_CONTRACT_ADDRESS=0xCF72FE0b40c8bbf4be48B905c20f0d1A0BcD33F3

# === Cloudflare R2 Storage — leave blank for local disk fallback ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=exchange-uploads
R2_PUBLIC_URL=

# === Messaging Service ===
MESSAGING_DB_PASSWORD=GENERATE_UNIQUE_PASSWORD

# === Stripe Payments — leave blank for simulation mode ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_FEE_PERCENTAGE=0.025

# === TypeORM (PRODUCTION) ===
# NEVER set TYPEORM_SYNCHRONIZE=true in production — it can destroy data
TYPEORM_SYNCHRONIZE=false
DB_LOGGING=false
